{
    "name": "ldap-gateway-server",
    "version": "1.0.0",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "main": "serverMain.js",
    "bin": {
        "ldap-gateway": "dist/ldap-gateway"
    },
    "scripts": {
        "start": "node index.js",
        "dev": "node index.js",
        "build": "node build.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:integration": "jest test/integration",
        "test:security": "jest test/integration/security",
        "test:e2e": "bash test/e2e/run-sssd-integration.sh",
        "test:db:mysql": "bash test/integration/sql/run-mysql.sh",
        "test:db:postgres": "bash test/integration/sql/run-postgres.sh",
        "test:db:mongodb": "bash test/integration/mongodb/run-mongodb.sh"
    },
    "dependencies": {
        "@ldap-gateway/core": "file:../npm",
        "@ldapjs/controls": "git+https://github.com/mieweb/controls.git",
        "argon2": "^0.31.2",
        "axios": "^1.12.0",
        "bcrypt": "^5.1.1",
        "chokidar": "4.0.3",
        "dotenv": "^16.4.7",
        "express": "^4.22.1",
        "ldapjs": "git+https://github.com/mieweb/node-ldapjs.git",
        "mongodb": "^6.14.2",
        "mysql2": "^3.2.0",
        "pg": "8.16.3",
        "selfsigned": "5.5.0",
        "sequelize": "6.37.7",
        "sqlite3": "5.1.7",
        "unixcrypt": "^1.2.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@types/jest": "30.0.0",
        "jest": "30.2.0",
        "sqlite": "5.1.1"
    }
}
