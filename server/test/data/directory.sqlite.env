LDAP_COMMON_NAME=example.com
LDAP_BASE_DN=dc=example,dc=com
PORT=6636

AUTH_BACKENDS=sql
DIRECTORY_BACKEND=sql

SQL_URI=sqlite://test001.sqlite
SQL_QUERY_ALL_USERS='SELECT * FROM users'
SQL_QUERY_ALL_GROUPS='SELECT * FROM groups'
SQL_QUERY_ONE_USER='SELECT * FROM users WHERE username = ?'
SQL_QUERY_GROUPS_BY_MEMBER='SELECT g.* FROM groups g JOIN user_groups ug ON g.gid_number = ug.gid_number JOIN users u ON ug.uid_number = u.uid_number WHERE u.username = ?'

ENABLE_NOTIFICATION=false
LOG_LEVEL=debug